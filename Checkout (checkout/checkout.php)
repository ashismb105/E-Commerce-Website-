<?php
session_start();
include("../config/db.php");

$cart = $_SESSION['cart'] ?? [];

$total = 0;

$conn->query("INSERT INTO orders (total) VALUES (0)");
$order_id = $conn->insert_id;

foreach ($cart as $id => $qty) {
    $result = $conn->query("SELECT price FROM products WHERE id=$id");
    $product = $result->fetch_assoc();

    $subtotal = $product['price'] * $qty;
    $total += $subtotal;

    $conn->query("INSERT INTO order_items (order_id, product_id, quantity)
                  VALUES ($order_id, $id, $qty)");
}

$conn->query("UPDATE orders SET total=$total WHERE id=$order_id");

unset($_SESSION['cart']);

echo "Order placed successfully!";
?>
